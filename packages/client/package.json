{
  "name": "cling-talk",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "cling-talk": "./bin/cling-talk.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsdown src/index.tsx --format esm --out-dir dist --external hyperswarm --external b4a --external hypercore-crypto --external sodium-native --external sodium-universal --external hyperdht --external dht-rpc --external @hyperswarm/dht",
    "test": "vitest run"
  },
  "dependencies": {
    "@cling-talk/shared": "*",
    "@inkjs/ui": "^2.0.0",
    "b4a": "^1.8.0",
    "chalk": "^5.6.2",
    "conf": "^15.1.0",
    "figlet": "^1.11.0",
    "hypercore-crypto": "^3.6.1",
    "hyperswarm": "^4.17.0",
    "ink": "^6.8.0",
    "nanoid": "^5.1.7",
    "react": "^19",
    "string-width": "^8.2.0",
    "ws": "^8.19.0",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/figlet": "^1",
    "@types/react": "^19",
    "@types/ws": "^8",
    "tsdown": "^0",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
