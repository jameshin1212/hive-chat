{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "noUncheckedIndexedAccess": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "references": [
    { "path": "packages/shared" },
    { "path": "packages/client" }
  ]
}
