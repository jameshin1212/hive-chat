{
  "name": "cling-talk-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "build": "npm -w packages/client run build",
    "dev": "npm -w packages/server run dev & sleep 1 && npm -w packages/client run dev",
    "dev:server": "npm -w packages/server run dev",
    "dev:client": "npm -w packages/client run dev",
    "dev:client2": "CLING_TALK_PROFILE=test2 npm -w packages/client run dev"
  },
  "devDependencies": {
    "concurrently": "^9",
    "vitest": "^3"
  }
}
